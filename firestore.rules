rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.userId == request.auth.uid &&
             data.fullName is string && data.fullName.size() <= 100 &&
             data.role in ['customer', 'driver'];
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && 
                      request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['fullName', 'phone', 'vehicleType', 'vehicleModel', 'plateNumber', 'photoURL', 'updatedAt', 'role', 'isVerified']);
    }

    match /rides/{rideId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        resource.data.customerId == request.auth.uid || 
        resource.data.driverId == request.auth.uid ||
        resource.data.status == 'requested'
      );
      allow update: if isSignedIn();
    }
  }
}
